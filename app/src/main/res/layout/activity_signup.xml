<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/tools"
    style="@style/MainScrollView"
    android:id="@+id/main">

    <LinearLayout
        style="@style/LinerLayout">

        <!-- Card View -->
        <androidx.cardview.widget.CardView
            style="@style/CollexaCardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >

            <LinearLayout
                style="@style/SecondaryLinear">

                <!-- App Title -->
                <TextView
                    style="@style/LightTextViwe"
                    android:text="Collexa Hub"
                    />

                <TextView
                    style="@style/SecondTextView"
                    android:text="Create your account"
                    />

                <!-- App Logo -->
                <ImageView
                    android:id="@+id/imgLogo"
                    style="@style/MainImageView"/>

                <!-- Full Name -->
                <EditText
                    android:id="@+id/etFullName"
                    style="@style/PrimaryEditText"
                    android:hint="Full Name"
                    android:inputType="textPersonName"
                    />

                <!-- Email -->
                <EditText
                    android:id="@+id/etEmail"
                    style="@style/PrimaryEditText"
                    android:hint="Email Address"
                    android:inputType="textEmailAddress"
                    />

                <!-- Mobile -->
                <EditText
                    android:id="@+id/etMobile"
                    style="@style/PrimaryEditText"
                    android:maxLength="10"
                    android:hint="Mobile Number"
                    android:inputType="phone"
                    />

                <!-- Gender -->
                <RadioGroup
                    android:layout_gravity="center"
                    android:id="@+id/rgGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <RadioButton

                        style="@style/Radio"
                        android:id="@+id/rbMale"
                        android:text="Male"
                        android:layout_weight="1"/>

                    <RadioButton
                        style="@style/Radio"
                        android:id="@+id/rbFemale"
                        android:text="Female"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/_12sdp"/>

                    <RadioButton
                        style="@style/Radio"
                        android:id="@+id/rbOther"
                        android:text="Other"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/_12sdp"/>
                </RadioGroup>


                <!-- Password -->
                <EditText
                    android:layout_marginTop="@dimen/_12sdp"
                    android:id="@+id/etPassword"
                    style="@style/PrimaryEditText"
                    android:hint="Password"
                    android:inputType="textPassword"
                    />

                <!-- Signup Button -->
                <Button
                    android:id="@+id/btnSignup"
                    style="@style/MainButton"
                    android:text="SIGN UP"
                     />

                <TextView
                    android:id="@+id/etLogin"
                    android:layout_marginTop="@dimen/_8sdp"
                    style="@style/SecondTextView"
                    android:text="Alredy have Account. Login"
                    />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
