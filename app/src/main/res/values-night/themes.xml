<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CollexaHub" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">@color/bg_screen_dark</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="colorPrimary">@color/yellow_primary</item>
        <item name="colorOnPrimary">@color/bg_screen</item>

    </style>

    <style name="MainScrollView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/bg_screen_dark</item>
        <item name="android:fillViewport">true</item>
    </style>

    <style name="LinerLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/_20sdp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="CollexaCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/_16sdp</item>
        <item name="cardElevation">@dimen/_8sdp</item>
        <item name="cardBackgroundColor">@color/bg_card_dark</item>
    </style>

    <style name="SecondaryLinear">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/_20sdp</item>
    </style>

    <style name="LightTextViwe">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:textSize">@dimen/_28sdp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:paddingBottom">@dimen/_4sdp</item>
    </style>

    <style name="SecondTextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary_dark</item>
        <item name="android:textSize">@dimen/_10sdp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:paddingBottom">@dimen/_10sdp</item>
    </style>

    <style name="MainImageView">
        <item name="android:layout_width">@dimen/_90sdp</item>
        <item name="android:layout_height">@dimen/_90sdp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:layout_marginBottom">@dimen/_16sdp</item>
        <item name="android:src">@drawable/sign_in_pana</item>
        <item name="android:contentDescription">Collexa Hub Logo</item>
    </style>

    <style name="PrimaryEditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_50sdp</item>
        <item name="android:textColor">@color/edittext_dark</item>
        <item name="android:textColorHint">@color/edittext_dark_second</item>
        <item name="android:padding">@dimen/_14sdp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:layout_marginBottom">@dimen/_14sdp</item>
    </style>

    <style name="MainButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_50sdp</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:backgroundTint">@color/yellow_primary</item>
        <item name="android:elevation">@dimen/_4sdp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/_12sdp</item>

    </style>

</resources>
