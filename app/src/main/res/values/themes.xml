<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CollexaHub" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">@color/bg_screen</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="colorPrimary">@color/yellow_primary</item>
        <item name="colorOnPrimary">@color/bg_screen</item>
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.CollexaHub" parent="Base.Theme.CollexaHub" />

    <style name="MainScrollView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/bg_screen</item>
        <item name="android:fillViewport">true</item>
    </style>

    <style name="LinerLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/_20sdp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="CollexaCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/_16sdp</item>
        <item name="cardElevation">@dimen/_8sdp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
    </style>

    <style name="SecondaryLinear">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/_20sdp</item>
    </style>

    <style name="LightTextViwe">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/_28sdp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:paddingBottom">@dimen/_4sdp</item>
    </style>

    <style name="SecondTextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/_10sdp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:paddingBottom">@dimen/_8sdp</item>
    </style>

    <style name="MainImageView">
        <item name="android:layout_width">@dimen/_90sdp</item>
        <item name="android:layout_height">@dimen/_90sdp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:layout_marginBottom">@dimen/_16sdp</item>
        <item name="android:src">@drawable/sign_in_pana</item>
        <item name="android:contentDescription">Collexa Hub Logo</item>
    </style>

    <style name="PrimaryEditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_50sdp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:padding">@dimen/_14sdp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:layout_marginBottom">@dimen/_14sdp</item>
    </style>

    <style name="Radio">
        <item name="android:gravity">center</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/_12sdp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:background">@drawable/bg_input</item>

    </style>
    <style name="MainButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_50sdp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:backgroundTint">@color/yellow_primary</item>
        <item name="android:elevation">@dimen/_4sdp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/_12sdp</item>

    </style>

    <style name="Theme.CollexaHub.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.CollexaHub.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.CollexaHub.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>